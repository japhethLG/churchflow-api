{
	"name": "churchflow-api",
	"version": "1.0.0",
	"description": "ChurchFlow backend — multi-tenant church management API",
	"private": true,
	"scripts": {
		"build": "nest build -b swc",
		"start": "nest start -b swc",
		"start:dev": "nest start -b swc -w",
		"start:debug": "nest start -b swc --debug -w",
		"start:prod": "node dist/main.js",
		"lint": "biome lint .",
		"format": "biome format . --write",
		"check": "biome check --write .",
		"check:staged": "lint-staged",
		"prisma:generate": "prisma generate",
		"prisma:migrate": "prisma migrate dev",
		"prisma:deploy": "prisma migrate deploy",
		"prisma:studio": "prisma studio",
		"prisma:seed": "tsx prisma/seed.ts",
		"prisma:reset": "prisma migrate reset && npm run prisma:seed",
		"seed:super-admin": "tsx scripts/seed-super-admin.ts",
		"test:integration": "vitest run",
		"test:integration:watch": "vitest",
		"prepare": "husky"
	},
	"lint-staged": {
		"*.{ts,tsx,js,jsx,mjs,cjs,json}": [
			"biome check --write --no-errors-on-unmatched"
		]
	},
	"dependencies": {
		"@casl/ability": "^6.8.1",
		"@casl/prisma": "^1.6.2",
		"@nestjs/cache-manager": "^3.0.0",
		"@nestjs/common": "^11.0.0",
		"@nestjs/config": "^4.0.0",
		"@nestjs/core": "^11.0.0",
		"@nestjs/event-emitter": "^3.0.0",
		"@nestjs/platform-express": "^11.0.0",
		"@nestjs/schedule": "^5.0.0",
		"@nestjs/swagger": "^11.2.6",
		"@nestjs/throttler": "^6.0.0",
		"@prisma/adapter-pg": "^7.5.0",
		"@prisma/client": "^7.5.0",
		"@scalar/nestjs-api-reference": "^0.4.2",
		"cache-manager": "^6.0.0",
		"class-transformer": "^0.5.1",
		"class-validator": "^0.14.1",
		"dayjs": "^1.11.20",
		"dotenv": "^16.4.5",
		"dotenv-expand": "^12.0.0",
		"firebase-admin": "^13.0.0",
		"nodemailer": "^8.0.6",
		"reflect-metadata": "^0.2.2",
		"rxjs": "^7.8.1"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.14",
		"@nestjs/cli": "^11.0.0",
		"@nestjs/schematics": "^11.0.0",
		"@swc/cli": "^0.5.2",
		"@swc/core": "^1.15.21",
		"@testcontainers/postgresql": "^11.14.0",
		"@types/express": "^5.0.0",
		"@types/node": "^22.0.0",
		"@types/nodemailer": "^8.0.0",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"prisma": "^7.5.0",
		"ts-loader": "^9.5.1",
		"ts-node": "^10.9.2",
		"tsconfig-paths": "^4.2.0",
		"tsx": "^4.21.0",
		"typescript": "^5.6.0",
		"vitest": "^4.1.6"
	}
}
