enum PledgeStatus {
  ACTIVE
  FULFILLED
  CANCELLED
}

// A member's commitment to give toward a campaign (optionally an item).
// Actual payments arrive as Transactions with pledgeId set.
model Pledge {
  id             String       @id @default(uuid())
  tenantId       String
  campaignId     String
  // Null = pledge applies to the overall campaign, not any single item.
  campaignItemId String?
  memberId       String
  pledgedAmount  Decimal      @db.Decimal(14, 2)
  // Denormalized running sum of transactions.amount for this pledge.
  // Maintained by TransactionFeatureService on every Tx create/update/
  // delete/restore. Backfilled on initial migration. Allows SQL-side
  // outstanding/fulfillment math without joining transactions.
  paidAmount     Decimal      @db.Decimal(14, 2) @default(0)
  status         PledgeStatus @default(ACTIVE)
  note           String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?
  deletedBy        String?
  deletedByCascade Boolean   @default(false)
  createdBy        String

  campaign     Campaign      @relation(fields: [campaignId], references: [id])
  campaignItem CampaignItem? @relation(fields: [campaignItemId], references: [id])
  member       Member        @relation(fields: [memberId], references: [id])
  transactions Transaction[]

  @@index([tenantId, campaignId])
  @@index([tenantId, memberId])
  @@index([tenantId, campaignItemId])
  @@index([tenantId, createdAt])
  @@index([tenantId, status])
}
